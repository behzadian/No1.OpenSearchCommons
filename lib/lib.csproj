<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<GeneratePackageOnBuild>true</GeneratePackageOnBuild>
		<PackageOutputPath>$(NUGET_HOME)</PackageOutputPath>
		<IsPackable>true</IsPackable>
		<AssemblyName>No1.OpenSearchCommons</AssemblyName>
		<RootNamespace>No1.OpenSearchCommons</RootNamespace>
		<Title>No1.OpenSearchCommons</Title>
		<Description>Contains some utility classes for using OpenSearch in .NET applications.</Description>
		<PackageProjectUrl>https://github.com/behzadian/No1.OpenSearchCommons</PackageProjectUrl>
		<PackageId>No1.OpenSearchCommons</PackageId>
		<Authors>Hank Benz</Authors>
		<Company>No1</Company>
		<Product>No1.OpenSearchCommons</Product>
		<Version>1.1.0</Version>
		<PublishRepositoryUrl>true</PublishRepositoryUrl>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<RepositoryUrl>git@github.com:behzadian/No1.OpenSearchCommons.git</RepositoryUrl>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
		<TreatWarningsAsErrors>true</TreatWarningsAsErrors>
		<NoWarn>CS1591,SA1600,SA1200,SA1601,SA1633,SA1500,RCS1194,SA1300,CA1054,CA1056</NoWarn>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<EnableNETAnalyzers>true</EnableNETAnalyzers>
		<AnalysisMode>AllEnabledByDefault</AnalysisMode>
		<AnalysisLevel>latest</AnalysisLevel>
		<EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
		<TreatWarningsAsErrors>true</TreatWarningsAsErrors>
	</PropertyGroup>
	<ItemGroup>
		<None Include="README.md" Pack="true" PackagePath="\" />
	</ItemGroup>

	<ItemGroup>
		<!-- Microsoft Code Analysis -->
		<PackageReference Include="Microsoft.CodeAnalysis.NetAnalyzers">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
		<PackageReference Include="No1.asp.NET.Commons" />
		<PackageReference Include="OpenSearch.Net" />

		<!-- StyleCop Analyzers -->
		<PackageReference Include="StyleCop.Analyzers">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>

		<!-- Roslynator -->
		<PackageReference Include="Roslynator.Analyzers">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>

		<!-- SonarAnalyzer -->
		<PackageReference Include="SonarAnalyzer.CSharp">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
	</ItemGroup>

	<ItemGroup>
		<InternalsVisibleTo Include="nest" />
	</ItemGroup>
	<ItemGroup>
		<FrameworkReference Include="Microsoft.AspNetCore.App" />
	</ItemGroup>

	<!-- Git hooks: skip in CI/Docker (no .git / not wanted in images). Local dev: run restore from repo root so dotnet-tools.json is found. -->
	<Target Name="InstallHusky" AfterTargets="Restore" Condition="'$(HUSKY)' != '0' AND '$(CI)' != 'true'">
		<Exec Command="dotnet tool restore" StandardOutputImportance="Low" />
		<Exec Command="dotnet husky install" StandardOutputImportance="Low" />
	</Target>
</Project>